# --- Supabase ---
# Public — exposed to the browser. Safe to ship.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never exposed to the client. Used solely by the cron route.
# Get this from: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron ---
# Shared secret used by Vercel Cron to authenticate calls to /api/cron/check-failures.
# Generate with: openssl rand -hex 32
CRON_SECRET=
