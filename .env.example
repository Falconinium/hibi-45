# --- Supabase ---
# Public — exposed to the browser. Safe to ship.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never exposed to the client. Used solely by the cron route.
# Get this from: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ---
# Public canonical URL of the deployed app, used to resolve OpenGraph image
# URLs in social shares. Defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=

# --- Cron ---
# Shared secret used by Vercel Cron to authenticate calls to /api/cron/check-failures.
# Generate with: openssl rand -hex 32
CRON_SECRET=
